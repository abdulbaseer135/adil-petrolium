# Set default behavior to automatically normalize line endings
* text=auto

# Shell scripts should always have LF line endings
*.sh text eol=lf

# Other Unix-specific files
*.md text eol=lf
*.json text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.html text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary