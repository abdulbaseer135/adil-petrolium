# Example environment file for local development
# DO NOT COMMIT real secrets to source control.
# Copy this to `.env` locally and populate secure values.

# MongoDB connection string (do not include this file in repo)
MONGO_URI=mongodb://<db_user>:<db_password>@<db_host>:27017/<db_name>

# JWT secrets (use long, random values)
JWT_ACCESS_SECRET=replace-with-a-secure-random-string
JWT_REFRESH_SECRET=replace-with-a-secure-random-string

# Admin registration secret used for one-time admin creation
ADMIN_REGISTRATION_SECRET=replace-with-strong-secret

# Logging level (avoid 'debug' in production)
LOG_LEVEL=info

# Test credentials - override in CI, do not use these in production
TEST_ADMIN_PASS=ChangeMeInCI
TEST_CUSTOMER_PASS=ChangeMeInCI

# WhatsApp / third-party tokens (leave empty if unused)
WHATSAPP_ADMIN_NUMBER=+00000000000
WHATSAPP_ACCESS_TOKEN=
NODE_ENV=development
PORT=5000
API_VERSION=v1

# MongoDB
MONGO_URI=mongodb://localhost:27017/petro_dealer

# JWT
JWT_ACCESS_SECRET=change_this_to_a_long_random_secret_min_64_chars
JWT_REFRESH_SECRET=change_this_to_another_long_random_secret_min_64_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
ALLOWED_ORIGINS=http://localhost:3000

# Admin registration guard
ADMIN_REGISTRATION_SECRET=change_this_admin_secret

# Logging
LOG_LEVEL=debug

# Test credentials (only for test environment)
TEST_ADMIN_EMAIL=admin@test.com
TEST_ADMIN_PASS=Admin@12345
TEST_CUSTOMER_EMAIL=customer@test.com
TEST_CUSTOMER_PASS=Customer@12345